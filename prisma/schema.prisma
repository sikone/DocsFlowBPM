generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER") // ADMIN, ADVANCED, USER
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents      Document[]
  createdFolders Folder[]      @relation("FolderCreator")
  sessions       Session[]
  activityLogs   ActivityLog[]
  comments       Comment[]
  assignedTasks  Task[]        @relation("AssignedTasks")
  createdTasks   Task[]        @relation("CreatedTasks")
  templates      DocumentTemplate[]
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  color       String   @default("#6b7280")
  icon        String   @default("folder")
  order       Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    Folder?       @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]      @relation("FolderTree")
  documents Document[]
  creator   User          @relation("FolderCreator", fields: [createdById], references: [id])
}

model DocumentType {
  id          String   @id @default(cuid())
  name        String
  systemName  String   @unique
  description String?
  icon        String   @default("file-text")
  color       String   @default("#6366f1")
  active      Boolean  @default(true)
  formSchema  String   @default("[]") // JSON array of field definitions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
  templates DocumentTemplate[]
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  typeId      String
  data        String   @default("{}") // JSON pre-filled field data
  icon        String   @default("file-text")
  color       String   @default("#6b7280")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type    DocumentType @relation(fields: [typeId], references: [id])
  creator User        @relation(fields: [createdById], references: [id])

  @@index([typeId])
  @@index([createdById])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  number      String?
  typeId      String
  folderId    String?
  status      String   @default("DRAFT") // DRAFT, IN_PROGRESS, APPROVED, REJECTED, COMPLETED
  data        String   @default("{}")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type     DocumentType @relation(fields: [typeId], references: [id])
  folder   Folder?      @relation(fields: [folderId], references: [id])
  creator  User         @relation(fields: [createdById], references: [id])
  comments Comment[]
  tasks    Task[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user     User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // LOGIN, LOGOUT, CREATE_DOCUMENT, EDIT_DOCUMENT, DELETE_DOCUMENT, CHANGE_STATUS, CREATE_FOLDER, DELETE_FOLDER, CREATE_USER, EDIT_USER, DELETE_USER
  entityType String? // Document, Folder, User, DocumentType
  entityId   String?
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  documentId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
  @@index([createdAt])
}

model ProcessDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  systemName  String   @unique
  version     Int      @default(1)
  status      String   @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  steps       String   @default("[]") // JSON: array of step definitions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  type         String    @default("APPROVAL") // APPROVAL, REVIEW, NOTIFICATION
  status       String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  documentId   String?
  assignedToId String
  createdById  String
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  document   Document? @relation(fields: [documentId], references: [id])
  assignedTo User     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  creator    User     @relation("CreatedTasks", fields: [createdById], references: [id])

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([documentId])
  @@index([createdAt])
}
